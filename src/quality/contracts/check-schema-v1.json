{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yourwebsquad-toolkit/schemas/check-schema-v1.json",
  "title": "Quality Check Payload v1",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "selected": { "type": "boolean" },
    "failed": { "type": "boolean" },
    "stats": { "type": ["object", "null"] },
    "metrics": { "type": ["object", "null"] },
    "issues": {
      "type": ["array", "null"],
      "items": { "type": "object" }
    },
    "links": { "type": ["object", "null"] }
  },
  "required": ["selected", "failed"]
}

